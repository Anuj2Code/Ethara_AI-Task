# Copy this to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB — get a free cluster at mongodb.com/atlas
# For Railway: add a MongoDB plugin and Railway auto-fills this
MONGODB_URI=mongodb://localhost:27017/taskflow

# JWT — generate a strong random string for production
# e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS — set to your frontend URL in production
# For Railway: set to your frontend Railway URL
CLIENT_URL=http://localhost:5173
